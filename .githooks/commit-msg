#!/bin/sh
# Remove atribuicao automatica ao Cursor injetada pelo ambiente.
MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0

TMP_FILE="${MSG_FILE}.cursor-strip"
grep -v -E -i '^(Co-authored-by: Cursor|Co-authored-by:.*cursoragent@cursor\.com|Made-with: Cursor)' "$MSG_FILE" > "$TMP_FILE"
mv "$TMP_FILE" "$MSG_FILE"
exit 0

{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/docs/competencias.md",
      "destination": "/docs/competencias",
      "permanent": true
    },
    {
      "source": "/docs/case-study-juris-sync.md",
      "destination": "/docs/case-study-juris-sync",
      "permanent": true
    },
    {
      "source": "/docs/deploy.md",
      "destination": "/docs/deploy",
      "permanent": true
    },
    {
      "source": "/docs/case-study-paycore.md",
      "destination": "/docs/case-study-paycore",
      "permanent": true
    },
    {
      "source": "/docs/case-study-mgi-kpi.md",
      "destination": "/docs/case-study-mgi-kpi",
      "permanent": true
    },
    {
      "source": "/docs/case-study-situacao-juridica.md",
      "destination": "/docs/case-study-situacao-juridica",
      "permanent": true
    }
  ]
}

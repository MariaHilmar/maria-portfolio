---
import BaseLayout from "./BaseLayout.astro";
import "../styles/doc-prose.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Documentação do portfólio Maria Hilmar." } = Astro.props;
---

<BaseLayout title={`${title} · Maria Hilmar`} description={description}>
  <header class="doc-nav wrap">
    <a class="brand" href="/">← Maria Hilmar</a>
    <nav aria-label="Documentação">
      <a href="/docs/competencias">Competências</a>
      <a href="/docs/case-study-juris-sync">Case study</a>
      <a href="/#projetos">Projetos</a>
    </nav>
  </header>

  <main class="doc-main wrap">
    <article class="doc-prose">
      <slot />
    </article>
  </main>

  <footer class="doc-footer wrap">
    <p>
      <a href="/">Voltar ao portfólio</a>
      ·
      <a href="https://github.com/MariaHilmar/maria-portfolio" target="_blank" rel="noreferrer">GitHub</a>
    </p>
  </footer>
</BaseLayout>

<style>
  .doc-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.25rem 0 0.5rem;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .doc-nav nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1rem;
  }

  .doc-nav nav a {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-soft);
    text-decoration: none;
  }

  .doc-nav nav a:hover {
    color: var(--teal-deep);
  }

  .doc-main {
    padding: 2rem 0 4rem;
  }

  .doc-footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .doc-footer p {
    margin: 0;
  }
</style>

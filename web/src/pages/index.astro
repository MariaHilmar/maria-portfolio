---
import BaseLayout from "../layouts/BaseLayout.astro";

const capabilities = [
  "Produto e requisitos",
  "APIs e dados",
  "Apps e BI",
  "Segurança e LGPD",
  "IA aplicada",
  "Qualidade",
];
---

<BaseLayout>
  <header class="site-header">
    <div class="nav wrap">
      <a class="brand" href="#topo">Maria Hilmar</a>
      <nav aria-label="Principal">
        <a href="#sobre">Sobre</a>
        <a href="#produto">Produto</a>
        <a href="#projetos">Projetos</a>
        <a href="#contato">Contato</a>
      </nav>
    </div>
  </header>

  <div class="hero-band">
    <main id="topo">
      <section class="hero wrap">
        <div class="hero-content">
          <p class="hero-kicker">Portfólio · Product Manager / Product Owner · Dados &amp; IA</p>
          <h1 class="hero-name">Maria Hilmar</h1>
          <p class="hero-tagline">
            Product Manager / Product Owner com foco em Dados e Inteligência Artificial.
            Liderança madura em squads ágeis, com projetos hands-on em Python e FastAPI na
            intersecção entre negócios e engenharia.
          </p>
          <div class="hero-cta">
            <a class="btn btn-hero" href="#produto">Produto próprio</a>
            <a class="btn btn-ghost hero-ghost" href="#projetos">Evidências públicas</a>
          </div>
        </div>
        <figure class="hero-figure">
          <img
            src="/visuals/hero-arch.svg"
            alt="Diagrama ilustrativo do fluxo Fontes, Staging, Serving, Analytics, Apps e IA"
            width="1400"
            height="800"
            decoding="async"
          />
        </figure>
      </section>
    </main>
  </div>

  <main>

    <section id="sobre" class="section wrap reveal">
      <span class="section-label">Sobre</span>
      <h2>Liderança de produto na intersecção com dados e IA</h2>
      <p class="section-lead">
        Histórico consolidado em gestão de squads ágeis e governança de software, com
        forte viés técnico. MBA em Ciência de Dados (BI &amp; Analytics). Amplitude em produto
        próprio de estudo; profundidade técnica em projetos públicos no GitHub.
      </p>
      <div class="about-grid">
        <div class="about-card">
          <h3>Bagagem de liderança</h3>
          <p>
            Gestão de squads ágeis multidisciplinares (Scrum, Kanban, Management 3.0),
            backlog orientado ao ROI, OKRs/KPIs, desenvolvimento de pessoas com 1:1s e
            feedbacks, e articulação entre C-Level, engenharia e clientes B2B.
          </p>
        </div>
        <div class="about-card">
          <h3>Bagagem técnica</h3>
          <p>
            Engenharia de requisitos (BDD/Gherkin, BPMN, UML, C4, APF), arquitetura SaaS,
            proximidade com engenharia de dados (bancos relacionais e vetoriais, pipelines
            ETL) e governança de QA (CTAL-TM). Python, FastAPI e PostgreSQL em estudo contínuo.
          </p>
        </div>
        <div class="about-card">
          <h3>Entregáveis técnicos</h3>
          <p>
            Código limpo orientado a padrões (SOLID, Design Patterns). Documentação viva no
            repositório (ADR, BDD/Gherkin, OpenAPI/Swagger). Escopo validado por critérios
            de aceite e garantido por evidências em pipelines de CI/CD (SonarQube).
          </p>
        </div>
      </div>
    </section>

    <section id="produto" class="band-dark section reveal">
      <div class="wrap">
        <span class="section-label on-dark">Produto próprio · código privado</span>
        <h2>Situação Jurídica</h2>
        <p class="section-lead on-dark">
          Ecossistema de jurimetria e dados jurídicos - estudo aplicado de Product Ownership
          com base técnica. <strong>Não é vínculo empregatício.</strong> Código e operação
          permanecem privados; abaixo, a visão do que o trabalho demonstra.
        </p>

        <div class="sj-layout">
          <div class="sj-copy">
            <div class="sj-block">
              <h3>Problema</h3>
              <p>
                Dados processuais fragmentados. É preciso ingestão, normalização, APIs,
                analytics e conformidade (LGPD) para apoiar decisões.
              </p>
            </div>
            <div class="sj-block">
              <h3>Papel</h3>
              <p>
                Product Owner / Product Lead: roadmap, requisitos, alinhamento com arquitetura,
                qualidade e jornadas de dados.
              </p>
            </div>
            <div class="sj-block">
              <h3>Resultados no ambiente do projeto</h3>
              <ul>
                <li>~60% menos latência após segregação staging/ETL versus serving</li>
                <li>~70% menos esforço de especificação com docs e BDD assistidos por IA</li>
                <li>Isolamento multi-tenant (RLS) e Privacy by Design / LGPD</li>
              </ul>
            </div>
            <div class="project-links">
              <a class="btn btn-primary" href="/docs/case-study-situacao-juridica">Case completo</a>
              <a class="btn btn-ghost on-dark-btn" href="/docs/competencias">Competências</a>
            </div>
          </div>
        </div>

        <p class="caps-label">Capacidades demonstradas no produto</p>
        <ul class="caps-row">
          {capabilities.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section id="projetos" class="section wrap reveal">
      <span class="section-label">Evidências públicas</span>
      <h2>Projetos com código aberto</h2>
      <p class="section-lead">
        Recortes técnicos para avaliação (clone + run). <strong>Não são o Situação Jurídica</strong>
        - são demonstrações independentes de API, testes, dashboard e BI.
      </p>

      <div class="projects-grid">
        <article class="project-card">
          <p class="evidence-kicker">Portfólio público · domínio jurídico</p>
          <h3>JurisSync</h3>
          <p>
            API FastAPI + dashboard Next.js (DataJud CNJ): sync idempotente, 43 testes em
            5 camadas, documentação viva. Avaliação local - mock ou dados reais.
          </p>
          <ul>
            <li>Pipeline DataJud → validação → persistência</li>
            <li>~90% cobertura · Testcontainers · Schemathesis</li>
            <li>Case study e CI públicos</li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://github.com/MariaHilmar/juris-sync" target="_blank" rel="noreferrer"
              >API</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/juris-sync-web" target="_blank" rel="noreferrer"
              >Dashboard</a
            >
            <a class="btn btn-ghost" href="/docs/case-study-juris-sync">Case study</a>
          </div>
        </article>

        <article class="project-card">
          <p class="evidence-kicker">Portfólio público · fintech</p>
          <h3>PayCore</h3>
          <p>
            Carteira digital com ledger de partidas dobradas, PIX simulado e transferências
            P2P idempotentes. Foco em correção financeira, concorrência e documentação SDD.
          </p>
          <ul>
            <li>Double-entry + conta de settlement (soma-zero)</li>
            <li>33 testes · ~88% cobertura · SELECT FOR UPDATE</li>
            <li>Docs: requisitos, C4, modelo de dados, segurança</li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://github.com/MariaHilmar/paycore" target="_blank" rel="noreferrer"
              >Repositório</a
            >
            <a class="btn btn-ghost" href="/docs/case-study-paycore">Case study</a>
          </div>
        </article>

        <article class="project-card">
          <p class="evidence-kicker">Portfólio público · BI de engenharia</p>
          <h3>MGI KPI</h3>
          <p>
            ETL Python (GitLab → Supabase) + dashboard Next.js somente leitura. Projeto de
            portfólio - não é sistema oficial do MGI.
          </p>
          <ul>
            <li>Upsert idempotente e RPCs PostgreSQL</li>
            <li>358 testes Vitest · SonarCloud</li>
            <li>Demo live com autenticação</li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://web-mgi-delog.vercel.app" target="_blank" rel="noreferrer"
              >Demo live</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/mgi-kpi-dashboard" target="_blank" rel="noreferrer"
              >Dashboard</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/mgi-kpi-pipeline" target="_blank" rel="noreferrer"
              >Pipeline</a
            >
          </div>
        </article>
      </div>
    </section>

    <section id="contato" class="section wrap reveal">
      <span class="section-label">Contato</span>
      <h2>Vamos conversar</h2>
      <p class="section-lead">
        Disponível para conversas sobre liderança de produto, dados, IA e projetos com
        profundidade técnica.
      </p>
      <div class="contact-row">
        <a class="btn btn-primary" href="https://www.linkedin.com/in/mariahilmar/" target="_blank" rel="noreferrer"
          >LinkedIn</a
        >
        <a class="btn btn-ghost" href="https://github.com/MariaHilmar" target="_blank" rel="noreferrer">GitHub</a>
        <a class="btn btn-ghost" href="mailto:mariahilmar@gmail.com">E-mail</a>
        <a class="btn btn-ghost" href="https://wa.me/5561982062117" target="_blank" rel="noreferrer">WhatsApp</a>
      </div>
    </section>
  </main>

  <footer class="footer wrap">
    <p>
      Maria Hilmar ·
      <a href="https://mariahilmar-portfolio.vercel.app">Live</a>
      · Product Manager / PO · Dados &amp; IA
    </p>
  </footer>
</BaseLayout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(12, 28, 34, 0.82);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(213, 232, 233, 0.12);
  }

  .hero-band {
    background:
      radial-gradient(700px 380px at 88% 20%, rgba(45, 154, 158, 0.28), transparent 60%),
      linear-gradient(180deg, #0c1c22 0%, #123038 60%, #1a3a42 100%);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: #f7fafb;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
  }

  .nav a {
    color: rgba(247, 250, 251, 0.82);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .nav a:hover {
    color: #9ed0d2;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    padding: 3rem 0 4.5rem;
  }

  .hero-content {
    animation: rise 0.9s ease both;
  }

  .btn-hero {
    background: #f7fafb;
    color: var(--ink);
  }

  .btn-hero:hover {
    background: #d5e8e9;
    color: var(--ink);
  }

  .hero-kicker {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9ed0d2;
    margin: 0 0 1rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.2rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
    color: #f7fafb;
  }

  .hero-tagline {
    max-width: 34rem;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: rgba(247, 250, 251, 0.85);
    margin: 0 0 2rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-ghost {
    border-color: rgba(247, 250, 251, 0.65);
    color: #f7fafb;
  }

  .hero-ghost:hover {
    background: rgba(247, 250, 251, 0.1);
    color: #f7fafb;
  }

  .hero-figure {
    margin: 0;
    animation: rise 1s ease 0.1s both;
  }

  .hero-figure img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    border: 1px solid rgba(213, 232, 233, 0.22);
    box-shadow: 0 24px 55px rgba(0, 0, 0, 0.35);
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .about-card {
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow);
  }

  .about-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }

  .about-card p {
    margin: 0;
    color: var(--ink-soft);
  }

  .band-dark {
    background:
      radial-gradient(800px 400px at 90% 10%, rgba(26, 107, 110, 0.35), transparent 55%),
      linear-gradient(180deg, #132028 0%, #1a2f36 100%);
    color: #f7fafb;
  }

  .band-dark h2,
  .band-dark h3 {
    color: #f7fafb;
  }

  .section-label.on-dark,
  .caps-label {
    color: #9ed0d2;
  }

  .section-lead.on-dark {
    color: rgba(247, 250, 251, 0.78);
  }

  .sj-layout {
    margin-bottom: 2.5rem;
  }

  .sj-copy {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem 2rem;
    align-items: start;
  }

  .sj-copy .project-links {
    grid-column: 1 / -1;
  }

  .sj-block h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }

  .sj-block p,
  .sj-block li {
    color: rgba(247, 250, 251, 0.78);
    margin: 0;
  }

  .sj-block ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .sj-block li + li {
    margin-top: 0.35rem;
  }

  .caps-label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.85rem;
  }

  .caps-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .caps-row li {
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(213, 232, 233, 0.35);
    border-radius: 6px;
    font-size: 0.9rem;
    color: #d5e8e9;
    background: rgba(247, 250, 251, 0.04);
  }

  .btn.on-dark-btn {
    border-color: rgba(247, 250, 251, 0.55);
    color: #f7fafb;
  }

  .btn.on-dark-btn:hover {
    background: rgba(247, 250, 251, 0.08);
    color: #f7fafb;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem;
  }

  .evidence-kicker {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.5rem;
  }

  .project-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .project-card p {
    color: var(--ink-soft);
    margin: 0 0 0.85rem;
  }

  .project-card ul {
    margin: 0 0 1.35rem;
    padding-left: 1.1rem;
    color: var(--ink-soft);
  }

  .project-card li + li {
    margin-top: 0.35rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 601px) and (max-width: 1100px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      padding: 1.5rem 0 3rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 601px) and (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 601px) and (max-width: 900px) {
    .sj-copy {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .nav {
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      padding: 1rem 0;
    }

    .nav nav {
      gap: 0.75rem 1rem;
      font-size: 0.9rem;
    }

    .hero {
      gap: 1.5rem;
      padding: 1rem 0 2.5rem;
    }

    .hero-name {
      font-size: clamp(2.6rem, 13vw, 3.4rem);
    }

    .hero-figure img {
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.3);
    }

    .sj-copy {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .caps-row li {
      font-size: 0.82rem;
      padding: 0.4rem 0.7rem;
    }

    .btn {
      padding: 0.8rem 1.1rem;
      font-size: 0.9rem;
    }

    .hero-cta .btn,
    .project-links .btn,
    .contact-row .btn {
      flex: 1 1 auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content {
      animation: none;
    }
  }
</style>

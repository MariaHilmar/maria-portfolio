---
import BaseLayout from "../layouts/BaseLayout.astro";

const capabilities = [
  "Produto e requisitos",
  "APIs e dados",
  "Apps e BI",
  "Segurança e LGPD",
  "IA aplicada",
  "Qualidade",
];
---

<BaseLayout>
  <header class="nav wrap">
    <a class="brand" href="#topo">Maria Hilmar</a>
    <nav aria-label="Principal">
      <a href="#produto">Produto</a>
      <a href="#projetos">Projetos</a>
      <a href="#contato">Contato</a>
    </nav>
  </header>

  <main id="topo">
    <section class="hero">
      <div class="hero-media" aria-hidden="true">
        <img
          src="/visuals/hero-arch.svg"
          alt=""
          width="1200"
          height="720"
          decoding="async"
        />
      </div>
      <div class="hero-content wrap">
        <p class="hero-kicker">Product Manager / Product Owner · Dados &amp; IA</p>
        <h1 class="hero-name">Maria Hilmar</h1>
        <p class="hero-tagline">
          Liderança de produto com base técnica: traduz regra de negócio em entregas
          testáveis, com proximidade real a Python, APIs e pipelines.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="#produto">Produto próprio</a>
          <a class="btn btn-ghost hero-ghost" href="#projetos">Evidências públicas</a>
        </div>
      </div>
    </section>

    <section id="produto" class="band-dark section reveal">
      <div class="wrap">
        <span class="section-label on-dark">Produto próprio · código privado</span>
        <h2>Situação Jurídica</h2>
        <p class="section-lead on-dark">
          Ecossistema de jurimetria e dados jurídicos - estudo aplicado de Product Ownership
          com base técnica. <strong>Não é vínculo empregatício.</strong> Código e operação
          permanecem privados; abaixo, a visão do que o trabalho demonstra.
        </p>

        <div class="sj-layout">
          <div class="sj-copy">
            <h3>Problema</h3>
            <p>
              Dados processuais fragmentados. É preciso ingestão, normalização, APIs,
              analytics e conformidade (LGPD) para apoiar decisões.
            </p>
            <h3>Papel</h3>
            <p>
              Product Owner / Product Lead: roadmap, requisitos, alinhamento com arquitetura,
              qualidade e jornadas de dados.
            </p>
            <h3>Resultados no ambiente do projeto</h3>
            <ul>
              <li>~60% menos latência após segregação staging/ETL versus serving</li>
              <li>~70% menos esforço de especificação com docs e BDD assistidos por IA</li>
              <li>Isolamento multi-tenant (RLS) e Privacy by Design / LGPD</li>
            </ul>
            <div class="project-links">
              <a class="btn btn-primary" href="/docs/case-study-situacao-juridica">Case completo</a>
              <a class="btn btn-ghost on-dark-btn" href="/docs/competencias">Competências</a>
            </div>
          </div>
          <figure class="sj-figure">
            <img
              src="/visuals/hero-arch.svg"
              alt="Diagrama ilustrativo do fluxo Fontes → Staging → Serving → Analytics, Apps e IA"
              width="1200"
              height="720"
              loading="lazy"
              decoding="async"
            />
            <figcaption>
              Arquitetura em alto nível - ilustrativa, sem exposição de código privado.
            </figcaption>
          </figure>
        </div>

        <p class="caps-label">Capacidades demonstradas no produto</p>
        <ul class="caps-row">
          {capabilities.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section id="projetos" class="section wrap reveal">
      <span class="section-label">Evidências públicas</span>
      <h2>Projetos com código aberto</h2>
      <p class="section-lead">
        Recortes técnicos para avaliação (clone + run). <strong>Não são o Situação Jurídica</strong>
        - são demonstrações independentes de API, testes, dashboard e BI.
      </p>

      <article class="evidence">
        <figure class="evidence-media">
          <img
            src="/visuals/preview-jurissync.svg"
            alt="Preview ilustrativa do dashboard JurisSync com jurimetria"
            width="960"
            height="560"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="evidence-body">
          <p class="evidence-kicker">Portfólio público · domínio jurídico</p>
          <h3>JurisSync</h3>
          <p>
            API FastAPI + dashboard Next.js (DataJud CNJ): sync idempotente, 43 testes em
            5 camadas, documentação viva. Avaliação local - mock ou dados reais.
          </p>
          <ul>
            <li>Pipeline DataJud → validação → persistência</li>
            <li>~90% cobertura · Testcontainers · Schemathesis</li>
            <li>Case study e CI públicos</li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://github.com/MariaHilmar/juris-sync" target="_blank" rel="noreferrer"
              >API</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/juris-sync-web" target="_blank" rel="noreferrer"
              >Dashboard</a
            >
            <a class="btn btn-ghost" href="/docs/case-study-juris-sync">Case study</a>
          </div>
        </div>
      </article>

      <article class="evidence evidence-alt">
        <figure class="evidence-media">
          <img
            src="/visuals/preview-mgi.svg"
            alt="Preview ilustrativa do dashboard MGI KPI com métricas de engenharia"
            width="960"
            height="560"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="evidence-body">
          <p class="evidence-kicker">Portfólio público · BI de engenharia</p>
          <h3>MGI KPI</h3>
          <p>
            ETL Python (GitLab → Supabase) + dashboard Next.js somente leitura. Projeto de
            portfólio - não é sistema oficial do MGI.
          </p>
          <ul>
            <li>Upsert idempotente e RPCs PostgreSQL</li>
            <li>358 testes Vitest · SonarCloud</li>
            <li>Demo live com autenticação</li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://web-mgi-delog.vercel.app" target="_blank" rel="noreferrer"
              >Demo live</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/mgi-kpi-dashboard" target="_blank" rel="noreferrer"
              >Dashboard</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/mgi-kpi-pipeline" target="_blank" rel="noreferrer"
              >Pipeline</a
            >
          </div>
        </div>
      </article>
    </section>

    <section id="contato" class="section wrap reveal">
      <span class="section-label">Contato</span>
      <h2>Vamos conversar</h2>
      <p class="section-lead">
        Disponível para conversas sobre liderança de produto, dados, IA e projetos com
        profundidade técnica.
      </p>
      <div class="contact-row">
        <a class="btn btn-primary" href="https://www.linkedin.com/in/mariahilmar/" target="_blank" rel="noreferrer"
          >LinkedIn</a
        >
        <a class="btn btn-ghost" href="https://github.com/MariaHilmar" target="_blank" rel="noreferrer">GitHub</a>
        <a class="btn btn-ghost" href="mailto:mariahilmar@gmail.com">E-mail</a>
        <a class="btn btn-ghost" href="https://wa.me/5561982062117" target="_blank" rel="noreferrer">WhatsApp</a>
      </div>
    </section>
  </main>

  <footer class="footer wrap">
    <p>
      Maria Hilmar ·
      <a href="https://mariahilmar-portfolio.vercel.app">Live</a>
      · Product Manager / PO · Dados &amp; IA
    </p>
  </footer>
</BaseLayout>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    position: relative;
    z-index: 2;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
  }

  .nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .nav a:hover {
    color: var(--teal);
  }

  /* Hero: full-bleed visual plane */
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: grid;
    align-items: end;
    overflow: hidden;
    margin-bottom: 0;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
  }

  .hero-media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(19, 32, 40, 0.92) 0%, rgba(19, 32, 40, 0.72) 42%, rgba(19, 32, 40, 0.28) 100%),
      linear-gradient(180deg, rgba(19, 32, 40, 0.2) 0%, rgba(19, 32, 40, 0.55) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 4rem 0 4.5rem;
    max-width: min(100% - 2rem, var(--max));
    animation: rise 0.9s ease both;
  }

  .hero-kicker {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9ed0d2;
    margin: 0 0 1rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 10vw, 6.6rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
    max-width: 10ch;
    color: #f7fafb;
  }

  .hero-tagline {
    max-width: 32rem;
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: rgba(247, 250, 251, 0.88);
    margin: 0 0 2rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-ghost {
    border-color: rgba(247, 250, 251, 0.65);
    color: #f7fafb;
  }

  .hero-ghost:hover {
    background: rgba(247, 250, 251, 0.1);
    color: #f7fafb;
  }

  .band-dark {
    background:
      radial-gradient(800px 400px at 90% 10%, rgba(26, 107, 110, 0.35), transparent 55%),
      linear-gradient(180deg, #132028 0%, #1a2f36 100%);
    color: #f7fafb;
  }

  .band-dark h2,
  .band-dark h3 {
    color: #f7fafb;
  }

  .section-label.on-dark,
  .caps-label {
    color: #9ed0d2;
  }

  .section-lead.on-dark {
    color: rgba(247, 250, 251, 0.78);
  }

  .sj-layout {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2.5rem;
  }

  .sj-copy h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin: 1.25rem 0 0.4rem;
  }

  .sj-copy h3:first-child {
    margin-top: 0;
  }

  .sj-copy p,
  .sj-copy li {
    color: rgba(247, 250, 251, 0.78);
  }

  .sj-copy ul {
    margin: 0.4rem 0 1.5rem;
    padding-left: 1.1rem;
  }

  .sj-copy li + li {
    margin-top: 0.35rem;
  }

  .sj-figure {
    margin: 0;
  }

  .sj-figure img {
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(213, 232, 233, 0.25);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.28);
  }

  .sj-figure figcaption {
    margin-top: 0.65rem;
    font-size: 0.88rem;
    color: rgba(247, 250, 251, 0.55);
  }

  .caps-label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.85rem;
  }

  .caps-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .caps-row li {
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(213, 232, 233, 0.35);
    border-radius: 6px;
    font-size: 0.9rem;
    color: #d5e8e9;
    background: rgba(247, 250, 251, 0.04);
  }

  .btn.on-dark-btn {
    border-color: rgba(247, 250, 251, 0.55);
    color: #f7fafb;
  }

  .btn.on-dark-btn:hover {
    background: rgba(247, 250, 251, 0.08);
    color: #f7fafb;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .evidence {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 1.75rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .evidence-alt {
    grid-template-columns: 1fr 1.15fr;
  }

  .evidence-alt .evidence-media {
    order: 2;
  }

  .evidence-media {
    margin: 0;
  }

  .evidence-media img {
    width: 100%;
    border-radius: 14px;
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    background: var(--paper);
  }

  .evidence-kicker {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.5rem;
  }

  .evidence-body h3 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .evidence-body p {
    color: var(--ink-soft);
    margin: 0 0 0.85rem;
  }

  .evidence-body ul {
    margin: 0 0 1.35rem;
    padding-left: 1.1rem;
    color: var(--ink-soft);
  }

  .evidence-body li + li {
    margin-top: 0.35rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
    }

    .hero-content {
      padding: 3rem 0 3.25rem;
    }

    .sj-layout,
    .evidence,
    .evidence-alt {
      grid-template-columns: 1fr;
    }

    .evidence-alt .evidence-media {
      order: 0;
    }

    .hero-media::after {
      background:
        linear-gradient(180deg, rgba(19, 32, 40, 0.55) 0%, rgba(19, 32, 40, 0.9) 70%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content {
      animation: none;
    }
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";

const cvFile = "MariaHilmar_Curriculo_ATS.pdf";
const cvHref = `/${cvFile}`;

const capabilities = [
  "Produto e requisitos",
  "APIs e dados",
  "Apps e BI",
  "Segurança e LGPD",
  "IA aplicada",
  "Qualidade",
];
---

<BaseLayout>
  <header class="site-header">
    <div class="nav wrap">
      <a class="brand" href="#topo">Maria Hilmar</a>
      <nav aria-label="Principal">
        <a href="#sobre">Sobre</a>
        <a href="#produto">Produto</a>
        <a href="#projetos">Projetos</a>
        <a href="#contato">Contato</a>
        <a class="nav-cv" href={cvHref} download={cvFile}>Currículo PDF</a>
      </nav>
    </div>
  </header>

  <div class="hero-band">
    <main id="topo">
      <section class="hero wrap">
        <div class="hero-content">
          <p class="hero-kicker">Portfólio · Product Manager / Product Owner · Dados &amp; IA</p>
          <h1 class="hero-name">Maria Hilmar</h1>
          <p class="hero-tagline">
            Product Manager / Product Owner especialista na intersecção entre Dados e
            Inteligência Artificial. Histórico consolidado em gestão de squads ágeis e governança
            de software, traduzindo regras de negócio e arquiteturas complexas (com projetos
            hands-on em Python e FastAPI) em produtos SaaS escaláveis com alto retorno financeiro
            (ROI).
          </p>
          <div class="hero-cta">
            <a class="btn btn-hero" href="#produto">Produto próprio</a>
            <a class="btn btn-ghost hero-ghost-muted" href="#projetos">Evidências públicas</a>
            <a class="btn btn-ghost hero-ghost" href={cvHref} download={cvFile}
              >Baixar Currículo (PDF)</a
            >
          </div>
        </div>
        <figure class="hero-figure">
          <img
            src="/visuals/hero-arch.svg"
            alt="Diagrama ilustrativo do fluxo Fontes, Staging, Serving, Analytics, Apps e IA"
            width="1400"
            height="800"
            decoding="async"
          />
        </figure>
      </section>
    </main>
  </div>

  <main>

    <section id="sobre" class="section wrap reveal">
      <span class="section-label">Sobre</span>
      <h2>Liderança de produto na intersecção com dados e IA</h2>
      <p class="section-lead">
        Histórico consolidado em gestão de squads ágeis e governança de software, com
        forte viés técnico. Traduzindo regras de negócio e arquiteturas complexas em produtos
        SaaS escaláveis com alto retorno financeiro (ROI).
      </p>
      <div class="about-grid">
        <div class="about-card">
          <h3>Estratégia, Dados &amp; Métricas (Foco em ROI)</h3>
          <p>
            <strong>Cultura Data-Driven:</strong> Gestão ponta a ponta (Discovery ao Go-live)
            usando OKRs e KPIs para sustentar uma taxa histórica de 95% de entrega de resultados.
          </p>
          <p>
            <strong>Produtos de Dados:</strong> Concepção de pipelines analíticos de dados e
            inteligência preditiva (ETL, SQL, ML) com histórico real de redução de até 15% em churn.
          </p>
          <p>
            <strong>Gestão de Alta Senioridade:</strong> Liderança e desenvolvimento de equipes
            multidisciplinares com retenção de talentos acima de 90%.
          </p>
        </div>
        <div class="about-card">
          <h3>Engenharia de Requisitos &amp; Arquitetura SaaS</h3>
          <p>
            <strong>Tradução Técnica:</strong> Especialista em destrinchar regulamentações e
            regras de negócio densas em diagramações visuais (C4 Model, BPMN, UML) e critérios
            de aceite claros (BDD/Gherkin).
          </p>
          <p>
            <strong>Arquitetura e Segurança:</strong> Domínio em premissas de sistemas
            Multi-tenant, segurança em banco de dados (Row-Level Security - RLS) e diretrizes
            de Privacy by Design / LGPD.
          </p>
          <p>
            <strong>Ecossistemas Complexos:</strong> Experiência prática na modernização de
            sistemas legados, fiscais e financeiros, mitigando erros de conciliação em até 95%.
          </p>
        </div>
        <div class="about-card">
          <h3>Produtividade com IA &amp; Governança de QA</h3>
          <p>
            <strong>Engenharia Assistida por IA:</strong> Uso de IA generativa aplicada para
            acelerar o ciclo de vida do software (SDLC), alcançando redução de até 70% no
            esforço de especificação técnica.
          </p>
          <p>
            <strong>Qualidade e Guardrails:</strong> Definição de estratégias avançadas de
            testes (CTAL-TM), validação de APIs REST e acompanhamento de métricas de
            eficiência técnica (Velocity e Lead Time).
          </p>
          <p>
            <strong>Documentação Viva:</strong> Garantia de integridade técnica através de
            padrões de design, logs de arquitetura (ADRs) e contratos públicos OpenAPI no
            repositório.
          </p>
        </div>
      </div>
    </section>

    <section id="produto" class="band-dark section reveal">
      <div class="wrap">
        <span class="section-label on-dark">Produto próprio · código privado</span>
        <h2>Situação Jurídica</h2>
        <p class="section-lead on-dark">
          Ecossistema de jurimetria e dados jurídicos de alta performance desenvolvido como
          iniciativa proprietária (Código e operação privados). Abaixo, a engenharia de produto
          e os impactos arquiteturais demonstrados no sistema:
        </p>

        <div class="sj-layout">
          <div class="sj-copy">
            <div class="sj-block">
              <h3>Problema</h3>
              <p>
                Dados processuais fragmentados. É preciso ingestão, normalização, APIs,
                analytics e conformidade (LGPD) para apoiar decisões de negócio.
              </p>
            </div>
            <div class="sj-block">
              <h3>Papel</h3>
              <p>
                <strong>Product Lead &amp; Architect:</strong> Concepção de roadmap estratégico,
                engenharia de requisitos com BDD, alinhamento de infraestrutura SaaS multi-tenant
                e governança de qualidade de dados.
              </p>
            </div>
            <div class="sj-block">
              <h3>Resultados no ambiente do projeto</h3>
              <ul>
                <li>~60% menos latência após segregação staging/ETL versus serving</li>
                <li>~70% menos esforço de especificação com docs e BDD assistidos por IA</li>
                <li>Isolamento multi-tenant (RLS) e Privacy by Design / LGPD</li>
              </ul>
            </div>
            <div class="project-links">
              <a class="btn btn-primary" href="/docs/case-study-situacao-juridica">Case completo</a>
              <a class="btn btn-ghost on-dark-btn" href="/docs/competencias">Competências</a>
            </div>
          </div>
        </div>

        <p class="caps-label">Capacidades demonstradas no produto</p>
        <ul class="caps-row">
          {capabilities.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section id="projetos" class="section wrap reveal">
      <span class="section-label">Evidências públicas</span>
      <h2>Projetos com código aberto</h2>
      <p class="section-lead">
        Recortes arquiteturais para avaliação técnica e execução local (Clone &amp; Run).
        Demonstrações independentes com foco em padrões de engenharia, concorrência e testes
        automatizados.
      </p>

      <div class="projects-grid">
        <article class="project-card">
          <p class="evidence-kicker">Portfólio público • fintech</p>
          <h3>PayCore</h3>
          <p>
            Motor de pagamentos distribuído estruturado com ledger de partidas dobradas,
            transferências P2P e concorrência financeira. Projetado sob abordagem de especificação
            assistida por IA (SDD).
          </p>
          <ul>
            <li>
              <strong>Double-entry Ledger:</strong> Arquitetura de soma-zero com conta de
              liquidação (settlement) para consistência contábil absoluta.
            </li>
            <li>
              <strong>Concorrência e Escala:</strong> Implementação de SELECT FOR UPDATE para
              mitigação de condições de corrida. Cobertura de ~88% em 33 testes integrados.
            </li>
            <li>
              <strong>Documentação Executiva:</strong> Modelagem visual em C4 Model, dicionário de
              dados relacional ACID e requisitos de segurança.
            </li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://github.com/MariaHilmar/paycore" target="_blank" rel="noreferrer"
              >Repositório</a
            >
            <a class="btn btn-ghost" href="/docs/case-study-paycore">Case study</a>
          </div>
        </article>

        <article class="project-card">
          <p class="evidence-kicker">Portfólio público • domínio jurídico</p>
          <h3>JurisSync</h3>
          <p>
            API robusta em FastAPI integrada a dashboard analítico Next.js para sincronização
            idempotente de dados processuais (DataJud CNJ). Foco em resiliência de pipelines e
            esteiras de automação de testes.
          </p>
          <ul>
            <li>
              <strong>Pipeline de Ingestão:</strong> Fluxo otimizado de validação de esquemas e
              persistência de dados em alta vazão.
            </li>
            <li>
              <strong>Resiliência &amp; QA:</strong> Estratégia de testes em 5 camadas com ~90% de
              cobertura utilizando Testcontainers e Schemathesis.
            </li>
            <li>
              <strong>Evidências:</strong> Case study de produto e pipelines de CI/CD públicos para
              auditoria técnica.
            </li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://github.com/MariaHilmar/juris-sync" target="_blank" rel="noreferrer"
              >API</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/juris-sync-web" target="_blank" rel="noreferrer"
              >Dashboard</a
            >
            <a class="btn btn-ghost" href="/docs/case-study-juris-sync">Case study</a>
          </div>
        </article>

        <article class="project-card">
          <p class="evidence-kicker">Portfólio público • BI de engenharia</p>
          <h3>MGI KPI</h3>
          <p>
            Pipeline de ETL escalável em Python integrado a dashboard analítico em Next.js para
            governança de métricas de engenharia. Projeto isolado para simulação de cargas de
            dados reais.
          </p>
          <ul>
            <li>
              <strong>Persistência Avançada:</strong> Operações de Upsert idempotentes e chamadas
              de procedimentos remotos (RPCs) nativos no PostgreSQL.
            </li>
            <li>
              <strong>Qualidade de Código:</strong> 358 testes automatizados via Vitest e análise
              estática de segurança integrada com SonarCloud.
            </li>
            <li>
              <strong>Demo Live:</strong> Interface funcional com autenticação integrada para
              validação da experiência do usuário final.
            </li>
          </ul>
          <div class="project-links">
            <a class="btn btn-primary" href="https://web-mgi-delog.vercel.app" target="_blank" rel="noreferrer"
              >Demo live</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/mgi-kpi-dashboard" target="_blank" rel="noreferrer"
              >Dashboard</a
            >
            <a class="btn btn-ghost" href="https://github.com/MariaHilmar/mgi-kpi-pipeline" target="_blank" rel="noreferrer"
              >Pipeline</a
            >
            <a class="btn btn-ghost" href="/docs/case-study-mgi-kpi">Case study</a>
          </div>
        </article>
      </div>
    </section>

    <section id="contato" class="section wrap reveal">
      <span class="section-label">Contato</span>
      <h2>Vamos impulsionar os resultados do seu negócio?</h2>
      <p class="section-lead">
        Aberta a oportunidades e conexões estratégicas sobre liderança de produto, governança
        de software, ecossistemas de dados e IA com alto viés técnico.
      </p>
      <div class="contact-row">
        <a class="btn btn-primary" href="https://www.linkedin.com/in/mariahilmar/" target="_blank" rel="noreferrer"
          >LinkedIn</a
        >
        <a class="btn btn-ghost" href="https://github.com/MariaHilmar" target="_blank" rel="noreferrer">GitHub</a>
        <a class="btn btn-ghost" href="mailto:mariahilmar@gmail.com">E-mail</a>
        <a class="btn btn-ghost" href="https://wa.me/5561982062117" target="_blank" rel="noreferrer">WhatsApp</a>
        <a class="btn btn-ghost" href={cvHref} download={cvFile}>Currículo PDF</a>
      </div>
    </section>
  </main>

  <footer class="footer wrap">
    <p>
      Maria Hilmar ·
      <a href="https://mariahilmar.vercel.app">Live</a>
      · Product Manager / PO · Dados &amp; IA
    </p>
  </footer>
</BaseLayout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(12, 28, 34, 0.82);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(213, 232, 233, 0.12);
  }

  .hero-band {
    background:
      radial-gradient(700px 380px at 88% 20%, rgba(45, 154, 158, 0.28), transparent 60%),
      linear-gradient(180deg, #0c1c22 0%, #123038 60%, #1a3a42 100%);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: #f7fafb;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.25rem;
  }

  .nav a {
    color: rgba(247, 250, 251, 0.82);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .nav a:hover {
    color: #9ed0d2;
  }

  .nav-cv {
    padding: 0.45rem 0.95rem;
    border: 1px solid rgba(247, 250, 251, 0.55);
    border-radius: 999px;
    color: #f7fafb;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .nav-cv:hover {
    color: #f7fafb;
    background: rgba(247, 250, 251, 0.1);
    border-color: rgba(247, 250, 251, 0.85);
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: stretch;
    padding: 3rem 0 4.5rem;
  }

  .hero-content {
    flex: 1 1 auto;
    min-width: 0;
    animation: rise 0.9s ease both;
  }

  .btn-hero {
    background: #f7fafb;
    color: var(--ink);
  }

  .btn-hero:hover {
    background: #d5e8e9;
    color: var(--ink);
  }

  .hero-kicker {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9ed0d2;
    margin: 0 0 1rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.2rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0 0 1.25rem;
    color: #f7fafb;
  }

  .hero-tagline {
    max-width: 34rem;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: rgba(247, 250, 251, 0.85);
    margin: 0 0 2rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-cta .btn {
    flex: 0 1 auto;
  }

  .hero-ghost-muted {
    border-color: #52525b;
    color: #d4d4d8;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .hero-ghost-muted:hover {
    border-color: #71717a;
    color: #f7fafb;
    background: rgba(247, 250, 251, 0.06);
  }

  .hero-ghost {
    border-color: rgba(247, 250, 251, 0.65);
    color: #f7fafb;
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .hero-ghost:hover {
    background: rgba(247, 250, 251, 0.1);
    color: #f7fafb;
    border-color: rgba(247, 250, 251, 0.85);
  }

  .hero-figure {
    flex: 1 1 auto;
    min-width: 0;
    margin: 0;
    animation: rise 1s ease 0.1s both;
  }

  .hero-figure img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    border: 1px solid rgba(213, 232, 233, 0.22);
    box-shadow: 0 24px 55px rgba(0, 0, 0, 0.35);
  }

  #sobre .section-lead {
    max-width: none;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .about-card {
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow);
  }

  .about-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }

  .about-card p {
    margin: 0;
    color: var(--ink-soft);
  }

  .about-card p + p {
    margin-top: 0.75rem;
  }

  .band-dark {
    background:
      radial-gradient(800px 400px at 90% 10%, rgba(26, 107, 110, 0.35), transparent 55%),
      linear-gradient(180deg, #132028 0%, #1a2f36 100%);
    color: #f7fafb;
  }

  .band-dark h2,
  .band-dark h3 {
    color: #f7fafb;
  }

  .section-label.on-dark,
  .caps-label {
    color: #9ed0d2;
  }

  .section-lead.on-dark {
    color: rgba(247, 250, 251, 0.78);
  }

  .sj-layout {
    margin-bottom: 2.5rem;
  }

  .sj-copy {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem 2rem;
    align-items: start;
  }

  .sj-copy .project-links {
    grid-column: 1 / -1;
  }

  .sj-block h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }

  .sj-block p,
  .sj-block li {
    color: rgba(247, 250, 251, 0.78);
    margin: 0;
  }

  .sj-block ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .sj-block li + li {
    margin-top: 0.35rem;
  }

  .caps-label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.85rem;
  }

  .caps-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .caps-row li {
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(213, 232, 233, 0.35);
    border-radius: 6px;
    font-size: 0.9rem;
    color: #d5e8e9;
    background: rgba(247, 250, 251, 0.04);
  }

  .btn.on-dark-btn {
    border-color: rgba(247, 250, 251, 0.55);
    color: #f7fafb;
  }

  .btn.on-dark-btn:hover {
    background: rgba(247, 250, 251, 0.08);
    color: #f7fafb;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem;
  }

  .evidence-kicker {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.5rem;
  }

  .project-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .project-card p {
    color: var(--ink-soft);
    margin: 0 0 0.85rem;
  }

  .project-card ul {
    flex: 1;
    margin: 0 0 1.35rem;
    padding-left: 1.1rem;
    color: var(--ink-soft);
  }

  .project-card .project-links {
    margin-top: auto;
  }

  .project-card li + li {
    margin-top: 0.35rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 901px) {
    .hero {
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
    }

    .hero-content,
    .hero-figure {
      flex: 1 1 0;
    }
  }

  @media (min-width: 901px) and (max-width: 1099px) {
    .hero-cta {
      flex-wrap: nowrap;
    }

    .hero-cta .btn {
      white-space: nowrap;
      padding: 0.72rem 0.9rem;
      font-size: 0.82rem;
    }
  }

  @media (min-width: 1100px) {
    .hero-cta {
      flex-wrap: nowrap;
    }

    .hero-cta .btn {
      white-space: nowrap;
      padding: 0.8rem 1.05rem;
      font-size: 0.9rem;
    }
  }

  @media (min-width: 601px) and (max-width: 1100px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 900px) {
    .hero {
      gap: 1.75rem;
      padding: 1.5rem 0 3rem;
    }

    .hero-figure {
      order: 2;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
